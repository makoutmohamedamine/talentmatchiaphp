# Copier vers backend_php/.env.
# Pour phpMyAdmin/XAMPP local, DB_USER=root et DB_PASSWORD= vide sont courants.

APP_ENV=local
APP_KEY=change-me-php-jwt-key
DEBUG=True

DB_CONNECTION=mysql
DB_NAME=newpro
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Dossier des CV uploades (relatif a backend_php/)
MEDIA_ROOT=media

# Intelligence artificielle (Groq) — obligatoire pour analyse CV et chat RH
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optionnel : chemin complet vers python.exe (extraction PDF via PyMuPDF)
# PYTHON_BINARY=C:\Users\Vous\AppData\Local\Python\pythoncore-3.14-64\python.exe

# Microsoft Outlook / Graph API (boite partagee cv@colorado.ma)
# Creer une App Registration Azure AD avec permission application Mail.Read (+ consentement admin)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
OUTLOOK_MAILBOX=cv@colorado.ma
OUTLOOK_MAX_MESSAGES=50
